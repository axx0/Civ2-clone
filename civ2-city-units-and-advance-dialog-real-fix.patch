+    private void DrawAdvanceArt(int x, int y, int width, int height)
+    {
+        if (_advanceImage is null)
+        {
+            return;
+        }
+
+        var texture = TextureCache.GetImage(_advanceImage);
+        if (texture.Width <= 0 || texture.Height <= 0)
+        {
+            return;
+        }
+
+        const int padding = 4;
+        var availableWidth = Math.Max(1, width - 2 * padding);
+        var availableHeight = Math.Max(1, height - 2 * padding);
+        var scale = MathF.Min(availableWidth / (float)texture.Width, availableHeight / (float)texture.Height);
+        var drawWidth = texture.Width * scale;
+        var drawHeight = texture.Height * scale;
+        var dest = new Rectangle(
+            x + padding + (availableWidth - drawWidth) / 2f,
+            y + padding + (availableHeight - drawHeight) / 2f,
+            drawWidth,
+            drawHeight);
+
+        Graphics.DrawTexturePro(texture,
+            new Rectangle(0, 0, texture.Width, texture.Height),
+            dest, Vector2.Zero, 0f, Color.White);
+    }
