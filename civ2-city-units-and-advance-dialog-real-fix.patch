+        private static IImageSource GetClassicUnitImageSource(Civ2Interface active, int index)
+        {
+            if (active.PicSources.TryGetValue("unit", out var sources) &&
+                index >= 0 && index < sources.Length &&
+                IsClassicUnitSprite(sources[index], active))
+            {
+                return sources[index];
+            }
+
+            // The FOSS artwork can be substituted into PicSources by the asset-replacement
+            // path. Fixed-size UI panels still need the original 64px Civ2 sprite, so build
+            // that source explicitly from UNITS.* when PicSources no longer points there.
+            return new BitmapStorage("UNITS",
+                new Rectangle(1 + 65 * (index % UnitColumns),
+                    1 + (active.UnitsPxHeight + 1) * (index / UnitColumns),
+                    OriginalUnitWidth, active.UnitsPxHeight),
+                transparencyPixel: active.Title.Contains("Test of Time", StringComparison.OrdinalIgnoreCase),
+                searchFlagLoc: true);
+        }
+
+        private static bool IsClassicUnitSprite(IImageSource source, Civ2Interface active)
+        {
+            return source is BitmapStorage bitmapStorage &&
+                   string.Equals(bitmapStorage.Filename, "UNITS", StringComparison.OrdinalIgnoreCase) &&
+                   Math.Abs(bitmapStorage.Location.Width - OriginalUnitWidth) < 0.01f &&
+                   Math.Abs(bitmapStorage.Location.Height - active.UnitsPxHeight) < 0.01f;
+        }
